    "# =============================================================================\n",
    "# Load CMIP6 data and compute IHTD and TPC diagnostics\n",
    "# =============================================================================\n",
    "\n",
    "def build_path(experiment, model, variable, member='r1i1p1f*'):\n",
    "    \"\"\"Construct a glob path for a CMIP6 variable.\"\"\"\n",
    "    return (\n",
    "        f'{BADC_ROOT}/*MIP/*/{model}/{experiment}/{member}/'\n",
    "        f'Amon/{variable}/*/latest/*.nc'\n",
    "    )\n",
    "\n",
    "\n",
    "def load_model(model, variable, member='r1i1p1f*'):\n",
    "    \"\"\"Load and concatenate historical + ssp245 for one model and variable.\"\"\"\n",
    "    datasets = []\n",
    "    for scen in SCENARIOS:\n",
    "        path = build_path(scen, model, variable, member)\n",
    "        ds = rename_cmip6(xr.open_mfdataset(path))\n",
    "        datasets.append(ds)\n",
    "    # historical first, then ssp245\n",
    "    return xr.concat([datasets[0], datasets[1]], dim='time')\n",
    "\n",
    "\n",
    "def compute_ihtd(ds_tas):\n",
    "    \"\"\"\n",
    "    Compute the Inter-Hemispheric Temperature Difference (IHTD).\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    ds_tas : xr.Dataset  Dataset with 'tas', 'x', 'y' dimensions.\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    ihtd : xr.DataArray  Annual 10-yr smoothed IHTD timeseries.\n",
    "    \"\"\"\n",
    "    weights = np.cos(np.deg2rad(ds_tas.y))\n",
    "    nh = ds_tas.tas.sel(y=slice(0, 90)).weighted(weights).mean(dim=['x', 'y'])\n",
    "    sh = ds_tas.tas.sel(y=slice(-90, 0)).weighted(weights).mean(dim=['x', 'y'])\n",
    "    ihtd_annual = (nh - sh).groupby('time.year').mean('time')\n",
    "    return ihtd_annual.rolling(year=SMOOTH_YRS, center=True).mean().dropna('year')\n",
    "\n",
    "\n",
    "def compute_tpc(ds_pr):\n",
    "    \"\"\"\n",
    "    Compute the Tropical Precipitation Centroid (TPC).\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    ds_pr : xr.Dataset  Dataset with 'pr', 'x', 'y' dimensions.\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    tpc : xr.DataArray  Annual 10-yr smoothed TPC latitude timeseries.\n",
    "    \"\"\"\n",
    "    pr_trop = ds_pr.pr.sel(y=slice(-20, 20))\n",
    "    weights = np.cos(np.deg2rad(pr_trop.y))\n",
    "    zonal   = pr_trop.mean(dim='x')\n",
    "    tpc_raw = pr_trop.y.weighted(zonal * weights).mean(dim='y')\n",
    "    tpc_annual = tpc_raw.groupby('time.year').mean('time')\n",
    "    return tpc_annual.rolling(year=SMOOTH_YRS, center=True).mean().dropna('year')\n",
    "\n",
    "\n",
    "# ── Process all models ────────────────────────────────────────────────────────\n",
    "\n",
    "model_registry = {}   # {model_name: {'institution': str, 'ihtd': da, 'tpc': da}}\n",
    "\n",
    "for model in mods_list:\n",
    "    try:\n",
    "        ds_tas = load_model(model, 'tas')\n",
    "        ds_pr  = load_model(model, 'pr')\n",
    "        model_registry[model] = {\n",
    "            'institution': ds_tas.attrs.get('institution_id', 'unknown'),\n",
    "            'source_id':   ds_tas.attrs.get('source_id',      model),\n",
    "            'ihtd':        compute_ihtd(ds_tas).sel(year=YEAR_RANGE),\n",
    "            'tpc':         compute_tpc(ds_pr).sel(year=YEAR_RANGE),\n",
    "        }\n",
    "        print(f\"  processed: {model}\")\n",
    "    except Exception as e:\n",
    "        print(f\"  SKIPPED {model}: {e}\")\n",
    "\n",
    "# ── Special cases ─────────────────────────────────────────────────────────────\n",
    "\n",
    "for institution, models in SPECIAL_CASES.items():\n",
    "    for model, member in models.items():\n",
    "        try:\n",
    "            ds_tas = load_model(model, 'tas', member=member)\n",
    "            ds_pr  = load_model(model, 'pr',  member=member)\n",
    "            model_registry[model] = {\n",
    "                'institution': institution,\n",
    "                'source_id':   model,\n",
    "                'ihtd':        compute_ihtd(ds_tas).sel(year=YEAR_RANGE),\n",
    "                'tpc':         compute_tpc(ds_pr).sel(year=YEAR_RANGE),\n",
    "            }\n",
    "            print(f\"  processed (special): {model}\")\n",
    "        except Exception as e:\n",
    "            print(f\"  SKIPPED (special) {model}: {e}\")\n",
    "\n",
    "# ── Remove models with incomplete TPC timeseries ──────────────────────────────\n",
    "\n",
    "expected_len = 241\n",
    "incomplete = [m for m, v in model_registry.items()\n",
    "              if len(v['tpc'].year) != expected_len]\n",
    "for model in incomplete:\n",
    "    print(f\"  Removing incomplete model: {model}\")\n",
    "    del model_registry[model]\n",
    "\n",
    "print(f\"\\nFinal model count: {len(model_registry)}\")"
   ]
