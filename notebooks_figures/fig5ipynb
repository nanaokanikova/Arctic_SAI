    "# =============================================================================\n",
    "# ERA5 — IHTD and TPC\n",
    "# =============================================================================\n",
    "\n",
    "def compute_era5_ihtd(ds, year_range=slice(1940, 2024)):\n",
    "    \"\"\"Compute annual IHTD from ERA5 2m temperature.\"\"\"\n",
    "    weights = np.cos(np.deg2rad(ds.latitude))\n",
    "    nh = ds.sel(latitude=slice(90, 0)).weighted(weights).mean(dim=['longitude', 'latitude'])\n",
    "    sh = ds.sel(latitude=slice(0, -90)).weighted(weights).mean(dim=['longitude', 'latitude'])\n",
    "    nh_yr = nh.groupby('valid_time.year').mean('valid_time')\n",
    "    sh_yr = sh.groupby('valid_time.year').mean('valid_time')\n",
    "    ihtd  = (nh_yr - sh_yr).rolling(year=SMOOTH_YRS, center=True).mean().dropna('year')\n",
    "    return ihtd.sel(year=year_range)\n",
    "\n",
    "\n",
    "def compute_era5_tpc(ds, lat_band=slice(20, -20), year_range=slice(1940, 2024)):\n",
    "    \"\"\"Compute annual TPC from ERA5 precipitation.\"\"\"\n",
    "    trop    = ds.sel(latitude=lat_band)\n",
    "    weights = np.cos(np.deg2rad(trop.latitude))\n",
    "    zonal   = trop.mean(dim='longitude').to_array()\n",
    "    tpc_raw = trop.latitude.weighted(zonal * weights).mean(dim='latitude')\n",
    "    tpc     = tpc_raw.rolling(year=SMOOTH_YRS, center=True).mean().dropna('year')\n",
    "    return tpc.sel(year=year_range)\n",
    "\n",
    "\n",
    "ds_era5_tas = xr.open_dataset('RA_data/ERA5-2m.nc')\n",
    "ds_era5_pr  = xr.open_dataset('RA_data/ERA5-precip.nc')\n",
    "\n",
    "n_months = (2025 - 1940) * 12\n",
    "ds_era5_tas = ds_era5_tas.isel(valid_time=np.arange(0, n_months))\n",
    "ds_era5_pr  = ds_era5_pr.isel(valid_time=np.arange(0, n_months))\n",
    "\n",
    "era5_precip_annual = ds_era5_pr.groupby('valid_time.year').mean('valid_time')\n",
    "\n",
    "era5_ihtd = compute_era5_ihtd(ds_era5_tas)\n",
    "era5_tpc  = compute_era5_tpc(era5_precip_annual)\n",
    "\n",
    "era5_ihtd_anom = era5_ihtd - era5_ihtd.sel(year=ERA5_BASE).mean()\n",
    "era5_tpc_anom  = era5_tpc  - era5_tpc.sel(year=ERA5_BASE).mean()"
   ]
