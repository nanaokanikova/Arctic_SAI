    "# =============================================================================\n",
    "# Anomalies and per-model regression statistics\n",
    "# =============================================================================\n",
    "\n",
    "def compute_anomaly(da, base_period):\n",
    "    \"\"\"Subtract the mean over base_period.\"\"\"\n",
    "    return da - da.sel(year=base_period).mean()\n",
    "\n",
    "\n",
    "def compute_regression(x, y):\n",
    "    \"\"\"OLS regression; returns (slope, r²).\"\"\"\n",
    "    slope, _, r, _, _ = sp.linregress(x, y)\n",
    "    return slope, r ** 2\n",
    "\n",
    "\n",
    "# Anomalies and regressions stored back into model_registry\n",
    "for model, data in model_registry.items():\n",
