    "# End-of-century (last N years) mean IHTD and TPC anomalies\n",
    "# =============================================================================\n",
    "\n",
    "LAST_YEARS = 45   # years averaged over for end-of-century scatter (2050-2100)\n",
    "\n",
    "\n",
    "def end_of_century_mean(model_data, key, var):\n",
    "    \"\"\"Return the mean of the last LAST_YEARS values of a model timeseries.\"\"\"\n",
    "    return float(model_data[key][var].isel(year=slice(-LAST_YEARS, None)).mean())\n",
    "\n",
    "\n",
    "for model, data in model_registry.items():\n",
    "    data['ihtd_anom_eoc'] = end_of_century_mean(model_registry, model, 'ihtd_anom')\n",
    "    data['tpc_anom_eoc']  = end_of_century_mean(model_registry, model, 'tpc_anom')\n",
    "\n",
    "# Arrays for regression\n",
    "ihtd_eoc = np.array([d['ihtd_anom_eoc'] for d in model_registry.values()])\n",
    "tpc_eoc  = np.array([d['tpc_anom_eoc']  for d in model_registry.values()])\n",
    "\n",
    "slope_eoc, intercept_eoc, r_eoc, _, _ = sp.linregress(ihtd_eoc, tpc_eoc)\n",
    "r2_eoc = r_eoc ** 2\n",
    "\n",
    "# Flattened full-timeseries regression (all years, all models pooled)\n",
    "ihtd_flat = np.concatenate([d['ihtd_anom'].values for d in model_registry.values()])\n",
    "tpc_flat  = np.concatenate([d['tpc_anom'].values  for d in model_registry.values()])\n",
    "\n",
    "slope_flat, intercept_flat, r_flat, _, _ = sp.linregress(ihtd_flat, tpc_flat)\n",
    "r2_flat = r_flat ** 2"
